#:kivy 2.3.1
#:import dp kivy.metrics.dp
#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import RingProgress widgets.ring_progress.RingProgress

# ---------------------------------------------------------------
# 共通パーツ
# ---------------------------------------------------------------
<PrimaryButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    bold: True
    canvas.before:
        Color:
            rgba: 0.31, 0.56, 0.97, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<GhostButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.75, 0.78, 0.85, 1
    canvas.before:
        Color:
            rgba: 0.14, 0.15, 0.19, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<ColorSwatch@ToggleButton>:
    swatch_hex: "#4F8EF7"
    group: "palette"
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: get_color_from_hex(self.swatch_hex)
        Ellipse:
            pos: self.pos
            size: self.size
        Color:
            rgba: (1, 1, 1, 1) if self.state == "down" else (0, 0, 0, 0)
        Line:
            circle: (self.center_x, self.center_y, self.width / 2 - dp(1.5))
            width: dp(2.2)

# ---------------------------------------------------------------
# 習慣カード(ホーム画面のリスト項目)
# ---------------------------------------------------------------
<HabitCard>:
    size_hint_y: None
    height: dp(64)
    padding: dp(14), dp(8)
    spacing: dp(14)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14)]

    Widget:
        size_hint_x: None
        width: dp(4)
        canvas.before:
            Color:
                rgba: get_color_from_hex(root.habit_color)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(2)]

    BoxLayout:
        orientation: "vertical"
        Label:
            text: root.habit_name
            color: 1, 1, 1, 1
            bold: True
            halign: "left"
            valign: "bottom"
            text_size: self.size
            font_size: "16sp"
        Label:
            text: (f"streak {root.streak} days") if root.streak else "start today"
            color: 0.6, 0.65, 0.75, 1
            font_size: "12sp"
            halign: "left"
            valign: "top"
            text_size: self.size

    Button:
        size_hint: None, None
        size: dp(40), dp(40)
        background_normal: ""
        background_down: ""
        background_color: 0, 0, 0, 0
        text: "done" if root.done_today else ""
        bold: True
        font_size: "11sp"
        color: 1, 1, 1, 1
        canvas.before:
            Color:
                rgba: (0.20, 0.75, 0.45, 1) if root.done_today else (0.25, 0.27, 0.33, 1)
            Ellipse:
                pos: self.pos
                size: self.size
        on_release: root.toggle()

# ---------------------------------------------------------------
# ホーム画面
# ---------------------------------------------------------------
<HomeScreen>:
    habit_list: habit_list
    ring: ring

    canvas.before:
        Color:
            rgba: 0.06, 0.07, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(20), dp(24), dp(20), dp(16)
        spacing: dp(16)

        BoxLayout:
            size_hint_y: None
            height: dp(96)
            spacing: dp(16)

            RingProgress:
                id: ring
                size_hint_x: None
                width: dp(96)

            BoxLayout:
                orientation: "vertical"
                Label:
                    text: "HabitGraph"
                    font_size: "22sp"
                    bold: True
                    color: 1, 1, 1, 1
                    halign: "left"
                    text_size: self.size
                    size_hint_y: None
                    height: dp(30)
                Label:
                    text: "today's progress: " + str(int(ring.progress * 100)) + "%"
                    color: 0.65, 0.7, 0.8, 1
                    halign: "left"
                    text_size: self.size

            GhostButton:
                text: "stats"
                size_hint: None, None
                size: dp(64), dp(36)
                pos_hint: {"center_y": 0.5}
                on_release: root.go_stats()

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                id: habit_list
                orientation: "vertical"
                spacing: dp(10)
                size_hint_y: None
                height: self.minimum_height
                padding: 0, 0, 0, dp(90)

    PrimaryButton:
        text: "+  New Habit"
        size_hint: None, None
        size: dp(180), dp(52)
        pos_hint: {"center_x": 0.5}
        y: dp(20)
        on_release: root.go_add()

# ---------------------------------------------------------------
# 習慣追加画面
# ---------------------------------------------------------------
<AddHabitScreen>:
    name_input: name_input
    palette_grid: palette_grid

    canvas.before:
        Color:
            rgba: 0.06, 0.07, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(28)
        spacing: dp(20)

        Label:
            text: "New Habit"
            font_size: "22sp"
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(32)
            halign: "left"
            text_size: self.size

        TextInput:
            id: name_input
            hint_text: "e.g. Read for 10 minutes"
            multiline: False
            size_hint_y: None
            height: dp(50)
            background_normal: ""
            background_active: ""
            background_color: 0.13, 0.14, 0.18, 1
            foreground_color: 1, 1, 1, 1
            hint_text_color: 0.5, 0.55, 0.65, 1
            padding: dp(14), dp(14)
            cursor_color: 1, 1, 1, 1

        Label:
            text: "accent color"
            color: 0.65, 0.7, 0.8, 1
            size_hint_y: None
            height: dp(20)
            halign: "left"
            text_size: self.size

        GridLayout:
            id: palette_grid
            cols: 6
            size_hint_y: None
            height: dp(48)
            spacing: dp(10)
            ColorSwatch:
                swatch_hex: "#4F8EF7"
                state: "down"
                on_state: root.pick_color(self.swatch_hex) if self.state == "down" else None
            ColorSwatch:
                swatch_hex: "#22C55E"
                on_state: root.pick_color(self.swatch_hex) if self.state == "down" else None
            ColorSwatch:
                swatch_hex: "#F97316"
                on_state: root.pick_color(self.swatch_hex) if self.state == "down" else None
            ColorSwatch:
                swatch_hex: "#EF4444"
                on_state: root.pick_color(self.swatch_hex) if self.state == "down" else None
            ColorSwatch:
                swatch_hex: "#A855F7"
                on_state: root.pick_color(self.swatch_hex) if self.state == "down" else None
            ColorSwatch:
                swatch_hex: "#EAB308"
                on_state: root.pick_color(self.swatch_hex) if self.state == "down" else None

        Widget:
            # spacer

        BoxLayout:
            size_hint_y: None
            height: dp(52)
            spacing: dp(12)
            GhostButton:
                text: "Cancel"
                on_release: root.cancel()
            PrimaryButton:
                text: "Save"
                on_release: root.save()

# ---------------------------------------------------------------
# 統計画面
# ---------------------------------------------------------------
<StatsScreen>:
    stat_list: stat_list

    canvas.before:
        Color:
            rgba: 0.06, 0.07, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(20), dp(24), dp(20), dp(16)
        spacing: dp(16)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            GhostButton:
                text: "< back"
                size_hint: None, None
                size: dp(80), dp(36)
                on_release: root.go_home()
            Label:
                text: "Weekly Stats"
                font_size: "20sp"
                bold: True
                color: 1, 1, 1, 1

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                id: stat_list
                orientation: "vertical"
                spacing: dp(12)
                size_hint_y: None
                height: self.minimum_height
